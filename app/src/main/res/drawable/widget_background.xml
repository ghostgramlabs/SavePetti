<?xml version="1.0" encoding="utf-8"?>
<!-- Cream "paper" panel matching the app surface, rounded to sit nicely on
     the home screen. Kept as a literal color so the widget doesn't depend on
     the Compose theme (which isn't available in RemoteViews). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFDF8EF" />
    <corners android:radius="20dp" />
    <stroke android:width="1dp" android:color="#1A000000" />
</shape>
